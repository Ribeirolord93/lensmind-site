# ============================================================
# LENSMIND — Variables de entorno
# ============================================================
# Você pode fazer deploy SEM configurar essas vars!
# O site detecta automaticamente — features ligam quando você
# preenche os IDs respectivos.
# ============================================================

# ----- Shopify Storefront API -----
# Pegue depois de instalar o app "Headless" da App Store
# (App Store → Headless → Add storefront → Reveal token)
SHOPIFY_STORE_DOMAIN=lensmind.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_STOREFRONT_API_VERSION=2024-10

# ----- SEO / OG -----
NEXT_PUBLIC_SITE_URL=https://lensmind.lat

# ----- Email de contato -----
NEXT_PUBLIC_CONTACT_EMAIL=hola@lensmind.lat

# ----- WhatsApp Business -----
# Formato: código do país + DDD + número, sem +, espaços ou hífens
# Ex: 5521967440808 (Brasil), 525512345678 (México)
NEXT_PUBLIC_WHATSAPP_NUMBER=5521967440808

# ----- Galeria do produto -----
# DEFAULT (omit or false): mostra as 4 fotos limpas que estão em /public/products
# (geradas profissionalmente, sem texto promocional).
# Mude pra "true" SOMENTE quando você fizer suas próprias fotos do produto e
# subir no Shopify (sem overlays de "AI Photography Glasses" etc).
NEXT_PUBLIC_USE_SHOPIFY_PHOTOS=false

# ----- Analytics (opcional, ativam quando preenchidos) -----
# Google Analytics 4 — pegue em https://analytics.google.com
# Formato: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# Meta Pixel (Facebook + Instagram) — pegue em business.facebook.com
# Formato: 16 dígitos numéricos
NEXT_PUBLIC_META_PIXEL_ID=

# ----- Email marketing (opcional) -----
# Klaviyo — quando integrar, descomente o código em
# app/api/subscribe/route.ts
KLAVIYO_API_KEY=
KLAVIYO_LIST_ID=
